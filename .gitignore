# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# PlatformIO / ESP32 generated artifacts
hardware/esp32_panic_button/.pio/
hardware/esp32_panic_button/build.log

# Secrets
etc/secrets/

# Local secret material (never commit)
.env
.env.*
*.pem
*.p12
*.pfx
android/key.properties
android/**/*.jks
android/**/*.keystore

# Local call diagnostics (generated during testing)
caller*.log
callee*.log
deviceA.log
deviceB.log
android/build/
