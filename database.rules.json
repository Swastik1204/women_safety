{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$deviceId": {
        "emergency_contacts": {
          "$contactId": {
            ".read": true,
            ".write": true,
            ".validate": "newData.hasChildren(['id', 'name', 'phone', 'createdAt'])"
          }
        }
      }
    }
  }
}
